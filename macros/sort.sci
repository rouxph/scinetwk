function L2=sort(L1)
    //  SciNetwk 
    // 
    // Syntax
    // sort(L)
    //
    // Parameters
    // L: list/vector 
    //
    // Description
    // sort the list L in decreasing order using gsort
    //
    // Examples
    //    L=grand(1,10,'uin',1,100)
    //    sort(L)

    //
    // See also
    //  gsort
    //
    // Authors
    //  Philippe Roux
    //
    L2=gsort(L1,'g','d')
endfunction
